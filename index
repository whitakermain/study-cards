<!doctype html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Adaptive Study Deck</title>
<style>
:root{--bg:#10131c;--card:#191e2b;--line:#313a4f;--text:#eee7d8;--muted:#8d96aa;--accent:#e0a458;--bad:#cf6152;--good:#4fb080}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,Georgia,serif;line-height:1.45}
.top{height:3px;background:linear-gradient(90deg,#6d5ae0,#35b0c9,#4fb87a,#e0a458,#d9694e)}
.wrap{max-width:760px;margin:0 auto;padding:18px 16px 50px}
h1{font-size:32px;margin:10px 0 2px}
h2{margin:10px 0}
button{font:inherit;color:inherit;background:none;border:0}
.hidden{display:none!important}
.meta,.small{font-family:Menlo,monospace;color:var(--muted);font-size:11px}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:14px 0}
.panel,.tile,.row,.btn{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px;text-align:left}
.tile h3{margin:0 0 8px}
.row{display:flex;gap:12px;align-items:center;margin:8px 0;width:100%}
.idx{font-family:Menlo,monospace;color:var(--muted);width:42px}
.grow{flex:1}
.badge{font-family:Menlo,monospace;font-size:10px;color:var(--accent)}
.actions{display:grid;gap:8px;margin-top:12px}
.two{grid-template-columns:1fr 1fr}
.three{grid-template-columns:1fr 1fr 1fr}
.btn{text-align:center}
.primary{background:var(--accent);color:#1b1308;font-weight:bold}
.back{font-family:Menlo,monospace;color:var(--muted);padding:10px 0}
.sect{font-family:Menlo,monospace;color:#636c80;font-size:11px;text-transform:uppercase;letter-spacing:.15em;margin:20px 0 10px}
.card{background:var(--card);border:1px solid var(--line);border-radius:20px;min-height:320px;padding:22px;margin:12px 0}
.tag{font-family:Menlo,monospace;color:#636c80;font-size:10px;text-transform:uppercase;letter-spacing:.1em}
.q{font-size:25px;margin:28px 0 16px}
.a{font-size:18px;color:#d8d3c7;border-top:1px solid var(--line);padding-top:16px}
.rail{height:3px;background:var(--line);border-radius:4px;overflow:hidden;margin:10px 0}
.rail span{display:block;background:var(--accent);height:100%;width:0}
textarea{width:100%;min-height:90px;background:#0b0e15;border:1px solid var(--line);color:var(--text);border-radius:12px;padding:12px;font:inherit}
.good{color:var(--good)}.bad{color:var(--bad)}
#exportBox{height:420px;font-family:Menlo,monospace;font-size:11px;width:100%}
.debug{white-space:pre-wrap;color:#d9694e;font-family:Menlo,monospace;font-size:11px;margin-top:12px}
@media(max-width:540px){.grid,.stats{grid-template-columns:1fr}.three{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>
<div class="top"></div>
<div class="wrap">

<noscript><div class="panel">JavaScript is blocked. This app needs JavaScript.</div></noscript>

<section id="home">
  <h1>Study Deck</h1>
  <div class="meta">adaptive deck · GitHub Pages version</div>

  <div class="stats">
    <div class="panel"><b id="statMaster">-</b><div class="meta">mastered</div></div>
    <div class="panel"><b id="statToday">-</b><div class="meta">today</div></div>
    <div class="panel"><b id="statCards">-</b><div class="meta">cards</div></div>
  </div>

  <div class="actions two">
    <button class="btn" id="profileBtn">Profile</button>
    <button class="btn" id="exportBtn">Export metadata</button>
  </div>

  <div class="sect">Subjects</div>
  <div id="subjects" class="grid"><div class="panel">Loading subjects...</div></div>
  <div id="debug" class="debug"></div>
</section>

<section id="subject" class="hidden">
  <button class="back" id="backHome">← Subjects</button>
  <h2 id="subjectTitle"></h2>
  <div id="classes"></div>
</section>

<section id="study" class="hidden">
  <button class="back" id="backClasses">← Classes</button>
  <div class="meta" id="studyLoc"></div>
  <div class="rail"><span id="bar"></span></div>

  <div class="card">
    <div class="tag" id="cardTag"></div>
    <div class="q" id="cardQ"></div>
    <div class="a hidden" id="cardA"></div>
    <div id="answerWrap" class="hidden">
      <textarea id="answerInput" placeholder="Type what you remember..."></textarea>
    </div>
    <div class="small" id="hint"></div>
  </div>

  <div id="studyActions"></div>

  <div id="feedback" class="panel hidden">
    <div class="sect" style="margin-top:0">Information feedback</div>
    <div class="actions three">
      <button class="btn feed" data-feed="useful">Useful</button>
      <button class="btn feed" data-feed="too_random">Too random</button>
      <button class="btn feed" data-feed="need_context">Need context</button>
      <button class="btn feed" data-feed="need_example">Need example</button>
      <button class="btn feed" data-feed="worth_deeper">Worth deeper</button>
      <button class="btn feed" data-feed="too_shallow">Too shallow</button>
    </div>
  </div>

  <div class="small" id="status"></div>
</section>

<section id="done" class="hidden">
  <div class="sect" id="doneMark"></div>
  <h2 id="doneTitle"></h2>
  <p class="small" id="doneBody"></p>
  <div class="actions">
    <button class="btn primary" id="continueBtn">Continue</button>
    <button class="btn" id="doneClasses">Back to classes</button>
  </div>
</section>

<section id="profile" class="hidden">
  <button class="back" id="profileBack">← Home</button>
  <h2>Learning Profile</h2>
  <div id="profileBody"></div>
</section>

<section id="export" class="hidden">
  <button class="back" id="exportBack">← Home</button>
  <h2>Metadata Export</h2>
  <p class="small">Copy this and paste it back into ChatGPT to improve future decks.</p>
  <textarea id="exportBox"></textarea>
  <div class="actions two">
    <button class="btn primary" id="copyBtn">Copy</button>
    <button class="btn" id="refreshBtn">Refresh</button>
  </div>
  <div class="small" id="copyStatus"></div>
</section>

</div>

<script>
(function(){
"use strict";

var APP_KEY = "study.deck.github.v1";
var PHASES = ["learn","test","hard","master"];
var TIME_WEIGHT = 0.06;
var INTERRUPT_MS = 45000;

var SEEDS = {
"Optics & Light":{
domain:"science",use:"photography and visual literacy",interests:["photography","light","visual culture","field observation"],
base:[
["What is light?","Electromagnetic radiation that can travel through a vacuum.","definition","foundation","waves"],
["What is refraction?","Bending of light as it changes speed between media.","definition","mechanism","light behavior"],
["Snell's law?","n1 sin(theta1) = n2 sin(theta2).","formula","core principle","lenses"],
["Why is the sky blue?","Rayleigh scattering redirects shorter blue wavelengths across the sky.","cause-effect","mechanism","color"],
["What does a polarizer do?","It transmits one polarization direction and blocks others.","application","application","photography"]
]},
"Mathematics":{
domain:"mathematics",use:"technical calculation and design tools",interests:["geometry","architecture","measurement","design"],
base:[
["Pythagorean theorem?","a^2 + b^2 = c^2 for a right triangle.","formula","core principle","geometry"],
["Quadratic formula?","x = (-b plus or minus sqrt(b^2 - 4ac)) / 2a.","formula","core principle","algebra"],
["What does a derivative represent?","Instantaneous rate of change or slope of a curve.","definition","mental model","calculus"],
["What is the golden ratio?","Phi is about 1.618, a proportion where a/b = (a+b)/a.","definition","design principle","proportion"],
["What is slope?","Rise over run; vertical change divided by horizontal change.","definition","core principle","geometry"]
]},
"Astronomy":{
domain:"science",use:"cosmic orientation and observation",interests:["navigation","cosmos","scale","field observation"],
base:[
["What is a light-year?","The distance light travels in one year.","definition","foundation","cosmology"],
["Order of planets from the Sun?","Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus, Neptune.","sequence","foundation","planets"],
["What is redshift?","Stretching of light to longer wavelengths.","definition","mechanism","cosmology"],
["What powers a main-sequence star?","Hydrogen fusion in the core.","cause-effect","mechanism","stars"],
["Kepler's first law?","Planets orbit in ellipses with the Sun at one focus.","definition","core principle","motion"]
]},
"Spanish":{
domain:"language",use:"conversation and travel",interests:["daily speech","travel","conversation","field use"],
base:[
["How do you say hello?","Hola.","translation","vocabulary","daily speech"],
["How do you ask how are you?","Como estas?","translation","application","conversation"],
["Ser vs estar?","Ser is identity or essence; estar is state or location.","comparison","core principle","grammar"],
["How do you say I have to work?","Tengo que trabajar.","translation","application","daily speech"],
["Por vs para?","Por = cause or means; para = purpose or destination.","comparison","core principle","grammar"]
]},
"Latin":{
domain:"language",use:"translation and historical literacy",interests:["ancient world","Roman","translation","grammar"],
base:[
["Six Latin cases?","Nominative, genitive, dative, accusative, ablative, vocative.","list","foundation","cases"],
["Conjugate sum, present?","sum, es, est, sumus, estis, sunt.","conjugation","core principle","verbs"],
["Translate carpe diem.","Seize the day.","translation","named example","phrases"],
["What is an ablative absolute?","A noun plus participle in the ablative giving circumstance.","definition","advanced","grammar"],
["Translate puer puellam amat.","The boy loves the girl.","translation","application","translation"]
]},
"Cuneiform":{
domain:"ancient writing",use:"ancient-world literacy",interests:["Mesopotamia","ancient writing","clay","scribes"],
base:[
["What is cuneiform?","A wedge-shaped writing system pressed into clay.","definition","foundation","writing"],
["Where did cuneiform begin?","Sumer in southern Mesopotamia.","fact","origin","writing"],
["Around when did cuneiform begin?","Around 3200 BCE.","date","timeline anchor","writing"],
